{
  // AgentGate Cloudflare Worker (TypeScript + Hono).
  //
  // Storage is configurable via the USE_R2 variable:
  //   - Default (USE_R2 "false"): D1-only — metadata AND encrypted blobs both in
  //     D1. Works on the free tier with no R2 subscription.
  //   - USE_R2 "true": D1 + R2 hybrid — blobs in R2 (better for very large
  //     bundles). Requires uncommenting the r2_buckets binding below, creating
  //     the bucket, and an account with R2 enabled.
  //
  // Expiry cleanup runs on a Cron Trigger either way.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentgate",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-30",

  // Static assets: /static/* (css/js/vendor), / (index.html), and the view
  // shells under /views/* that the Worker serves for /p /f /app /plan /d.
  // Populated from ../web/static by `npm run sync-assets` (single source of truth).
  "assets": { "directory": "./public", "binding": "ASSETS" },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentgate",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ],

  // To enable R2 (paid): uncomment this block, run
  // `npx wrangler r2 bucket create agentgate-blobs`, and set USE_R2 to "true".
  // "r2_buckets": [
  //   { "binding": "BLOBS", "bucket_name": "agentgate-blobs" }
  // ],

  // Hourly expired-record cleanup (replaces the self-host cleanup goroutine).
  "triggers": { "crons": ["0 * * * *"] },

  // BASE_URL: public URL for preview/manage links (set after first deploy).
  // USE_R2: "true" to use the D1 + R2 hybrid; anything else = D1-only.
  "vars": { "BASE_URL": "http://localhost:8787", "USE_R2": "false" }
}
